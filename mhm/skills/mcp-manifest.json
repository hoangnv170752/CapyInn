{
    "name": "capyinn",
    "version": "0.1.0",
    "description": "CapyInn MCP Server — manage rooms, bookings, pricing, and reservations for a hotel.",
    "protocol": "mcp",
    "transport": {
        "stdio": {
            "command": "capyinn",
            "args": [
                "--mcp-stdio"
            ],
            "env": {
                "CAPYINN_API_KEY": "<your-api-key>"
            }
        },
        "streamable-http": {
            "url": "http://127.0.0.1:61234/mcp"
        }
    },
    "tools": [
        {
            "name": "get_hotel_context",
            "description": "Get the current date/time, timezone, and hotel context. ALWAYS call this first to ground your responses in reality and avoid date hallucinations.",
            "inputSchema": {
                "type": "object",
                "properties": {}
            }
        },
        {
            "name": "check_availability",
            "description": "Check room availability for a specific date range. Returns conflicts if any.",
            "inputSchema": {
                "type": "object",
                "required": [
                    "room_id",
                    "from_date",
                    "to_date"
                ],
                "properties": {
                    "room_id": {
                        "type": "string"
                    },
                    "from_date": {
                        "type": "string",
                        "description": "YYYY-MM-DD"
                    },
                    "to_date": {
                        "type": "string",
                        "description": "YYYY-MM-DD"
                    }
                }
            }
        },
        {
            "name": "get_rooms",
            "description": "Get list of all rooms with their current status (vacant, occupied, cleaning, booked).",
            "inputSchema": {
                "type": "object",
                "properties": {}
            }
        },
        {
            "name": "get_room_detail",
            "description": "Get detailed info for a specific room including current booking and guests.",
            "inputSchema": {
                "type": "object",
                "required": [
                    "room_id"
                ],
                "properties": {
                    "room_id": {
                        "type": "string"
                    }
                }
            }
        },
        {
            "name": "get_room_types",
            "description": "Get all room types and their names (e.g. standard, deluxe).",
            "inputSchema": {
                "type": "object",
                "properties": {}
            }
        },
        {
            "name": "get_dashboard_stats",
            "description": "Get hotel dashboard statistics: total rooms, occupied, vacant, cleaning, revenue today.",
            "inputSchema": {
                "type": "object",
                "properties": {}
            }
        },
        {
            "name": "get_all_bookings",
            "description": "Get all bookings with optional filters by status, date range.",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "status": {
                        "type": "string",
                        "enum": [
                            "active",
                            "booked",
                            "completed",
                            "cancelled"
                        ]
                    },
                    "from": {
                        "type": "string",
                        "description": "YYYY-MM-DD"
                    },
                    "to": {
                        "type": "string",
                        "description": "YYYY-MM-DD"
                    }
                }
            }
        },
        {
            "name": "get_rooms_availability",
            "description": "Get all room availability overview including upcoming reservations for each room.",
            "inputSchema": {
                "type": "object",
                "properties": {}
            }
        },
        {
            "name": "get_pricing_rules",
            "description": "Get pricing rules for all room types (hourly, overnight, daily rates and surcharges).",
            "inputSchema": {
                "type": "object",
                "properties": {}
            }
        },
        {
            "name": "get_hotel_info",
            "description": "Get a hotel setting by key. Common keys: hotel_name, hotel_address, hotel_phone, hotel_rules.",
            "inputSchema": {
                "type": "object",
                "required": [
                    "key"
                ],
                "properties": {
                    "key": {
                        "type": "string"
                    }
                }
            }
        },
        {
            "name": "calculate_price",
            "description": "Calculate estimated price for a stay. Supports nightly, hourly, overnight, and daily pricing types.",
            "inputSchema": {
                "type": "object",
                "required": [
                    "room_type",
                    "check_in",
                    "check_out",
                    "pricing_type"
                ],
                "properties": {
                    "room_type": {
                        "type": "string"
                    },
                    "check_in": {
                        "type": "string",
                        "description": "ISO 8601 datetime"
                    },
                    "check_out": {
                        "type": "string",
                        "description": "ISO 8601 datetime"
                    },
                    "pricing_type": {
                        "type": "string",
                        "enum": [
                            "nightly",
                            "hourly",
                            "overnight",
                            "daily"
                        ]
                    }
                }
            }
        },
        {
            "name": "create_reservation",
            "description": "Create a new reservation (booking with status 'booked'). The reservation must be confirmed by hotel staff before check-in.",
            "inputSchema": {
                "type": "object",
                "required": [
                    "room_id",
                    "guest_name",
                    "guest_phone",
                    "check_in_date",
                    "check_out_date",
                    "nights"
                ],
                "properties": {
                    "room_id": {
                        "type": "string"
                    },
                    "guest_name": {
                        "type": "string"
                    },
                    "guest_phone": {
                        "type": "string"
                    },
                    "guest_doc_number": {
                        "type": "string"
                    },
                    "check_in_date": {
                        "type": "string",
                        "description": "YYYY-MM-DD"
                    },
                    "check_out_date": {
                        "type": "string",
                        "description": "YYYY-MM-DD"
                    },
                    "nights": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "deposit_amount": {
                        "type": "number"
                    },
                    "source": {
                        "type": "string",
                        "default": "ai-agent"
                    },
                    "notes": {
                        "type": "string"
                    }
                }
            }
        },
        {
            "name": "cancel_reservation",
            "description": "Cancel an existing reservation. Only reservations with status 'booked' can be cancelled.",
            "inputSchema": {
                "type": "object",
                "required": [
                    "booking_id"
                ],
                "properties": {
                    "booking_id": {
                        "type": "string"
                    }
                }
            }
        },
        {
            "name": "modify_reservation",
            "description": "Modify an existing reservation's dates. Only reservations with status 'booked' can be modified.",
            "inputSchema": {
                "type": "object",
                "required": [
                    "booking_id",
                    "new_check_in_date",
                    "new_check_out_date",
                    "new_nights"
                ],
                "properties": {
                    "booking_id": {
                        "type": "string"
                    },
                    "new_check_in_date": {
                        "type": "string",
                        "description": "YYYY-MM-DD"
                    },
                    "new_check_out_date": {
                        "type": "string",
                        "description": "YYYY-MM-DD"
                    },
                    "new_nights": {
                        "type": "integer",
                        "minimum": 1
                    }
                }
            }
        }
    ]
}
